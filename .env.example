# Database Configuration
DB_URL=jdbc:postgresql://localhost:5432/mysawit
DB_USERNAME=postgres
DB_PASSWORD=postgres
JPA_SHOW_SQL=false

# JWT Configuration
JWT_SECRET=change-me-in-production-min-256-bits
JWT_EXPIRATION_MS=86400000

# Cloudflare R2 Storage Configuration
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET=mysawit-bucket
R2_ACCESS_KEY=placeholder
R2_SECRET_KEY=placeholder
R2_PUBLIC_URL=https://pub-<hash>.r2.dev

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Google OAuth2 Configuration
GOOGLE_CLIENT_ID=placeholder
GOOGLE_CLIENT_SECRET=placeholder
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/google/callback

APP_FRONTEND_URL=http://localhost:3000

# Server Configuration
SERVER_PORT=8080

# Logging Configuration
LOG_LEVEL=INFO

# CORS Configuration (comma-separated origins)
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001